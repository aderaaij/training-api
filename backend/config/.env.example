# App config for running the backend OUTSIDE Docker (fastapi dev / pytest on
# the host). A docker compose install needs no file here — copy the repo-root
# .env.example instead.
DATABASE_URL=postgresql+psycopg://training-api:training-api@localhost:5432/training-api
ENVIRONMENT=LOCAL

# First-run admin bootstrap (see README "Quick Start"). In Docker these come
# from the root .env via docker-compose.yml.
#BOOTSTRAP_ADMIN_USERNAME=admin
#BOOTSTRAP_ADMIN_PASSWORD=

# Legacy single-user key from before per-user auth. Only relevant when
# upgrading a pre-auth install: it is seeded as a token owned by the admin
# account so existing clients keep working. Fresh installs leave it unset.
#API_KEY=
